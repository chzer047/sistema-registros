<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Consulta de Registros</title>

<style>
body {
  font-family: Arial;
  background: #0f0f0f;
  color: #fff;
  text-align: center;
  padding: 40px;
}

input {
  width: 300px;
  padding: 12px;
  border-radius: 8px;
  border: none;
  margin-right: 10px;
}

button {
  padding: 12px 20px;
  border: none;
